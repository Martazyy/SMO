<Window x:Class="SMOapp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализ СМО — Системы Массового Обслуживания" 
        Height="780" 
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель — Параметры -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="0,0,20,0">

            <StackPanel>
                <TextBlock Text="Анализ СМО" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Тип системы массового обслуживания"/>
                <ComboBox x:Name="cboSMOType" 
                          Margin="0,6,0,15"
                          Height="34"
                          SelectionChanged="CboSMOType_SelectionChanged">
                    <ComboBoxItem Content="СМО с отказами"/>
                    <ComboBoxItem Content="СМО с ограниченной очередью"/>
                    <ComboBoxItem Content="СМО с неограниченной очередью"/>
                </ComboBox>

                <TextBlock Text="Количество каналов обслуживания (n)"/>
                <TextBox x:Name="txtChannels" Margin="0,6,0,12"/>

                <TextBlock Text="Интенсивность поступления заявок (λ)"/>
                <TextBox x:Name="txtLambda" Margin="0,6,0,12"/>

                <TextBlock Text="Интенсивность обслуживания (μ)"/>
                <TextBox x:Name="txtMu" Margin="0,6,0,12"/>

                <TextBlock Text="Среднее время обслуживания (tобс)"/>
                <TextBox x:Name="txtTob" Margin="0,6,0,15"/>

                <!-- Панель очереди -->
                <StackPanel x:Name="QueuePanel">
                    <TextBlock Text="Максимальный размер очереди (m)"/>
                    <TextBox x:Name="txtQueue" Margin="0,6,0,15"/>
                </StackPanel>

                <!-- Кнопки действий -->
                <UniformGrid Columns="2" Margin="0,10">
                    <Button Content="Рассчитать" 
                            Click="BtnCalculate_Click"
                            Background="#0078D7" 
                            Foreground="White" 
                            FontWeight="Bold" Height="42"/>

                    <Button Content="Очистить" 
                            Click="BtnClear_Click"
                            Background="#E74C3C" 
                            Foreground="White" Height="42"/>
                </UniformGrid>

                <!-- Работа с файлами -->
                <GroupBox Header="Работа с файлами" Margin="0,20,0,0">
                    <UniformGrid Rows="2" Margin="10">
                        <Button Content="Загрузить из файла" 
                                Click="BtnLoadFromFile_Click"/>
                        <Button Content="Сохранить результат" 
                                Click="BtnSaveResult_Click"/>
                    </UniformGrid>
                </GroupBox>
            </StackPanel>
        </Border>

        <!-- Правая панель — Результат -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="12"
                Padding="20">

            <StackPanel>
                <TextBlock Text="Результаты расчёта" 
                           FontSize="19" 
                           FontWeight="Bold" 
                           Margin="0,0,0,12"/>

                <TextBox x:Name="txtResult"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         Background="#FAFAFA"
                         BorderThickness="0"
                         Height="620"
                         Padding="10"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>